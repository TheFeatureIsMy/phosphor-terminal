{
  "$schema": "https://raw.githubusercontent.com/nicholasq/tauri-v2-schema/main/tauri.conf.schema.json",
  "productName": "PulseDesk",
  "version": "0.1.0",
  "identifier": "com.pulsedesk.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "PulseDesk",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": true,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "tabbingIdentifier": "pulsedesk"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
